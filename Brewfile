# Developer tooling for Claude Manager.
# Install with:  brew bundle
brew "xcodegen"    # generates ClaudeManager.xcodeproj from project.yml
brew "swiftformat" # code formatter (pre-commit hook + CI lint)
brew "swiftlint"   # linter (pre-commit hook + CI lint)
brew "create-dmg"  # release DMG packaging (optional; scripts fall back to hdiutil)
