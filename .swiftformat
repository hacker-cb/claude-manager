# SwiftFormat configuration — see https://github.com/nicklockwood/SwiftFormat
--swiftversion 6.0
# Keep single-line conditional bodies compact (`if x { return }`). SwiftFormat 0.62
# turned this rule on by default (it was `wrapConditionalBodies`, disabled, in 0.61);
# we deliberately keep the compact style, so disable it explicitly.
--disable wrapIfStatementBodies
--self remove
--importgrouping testable-bottom
--commas inline
--trimwhitespace always
--indent 4
--maxwidth 110
--wraparguments before-first
--wrapparameters before-first
--wrapcollections before-first
--funcattributes prev-line
--typeattributes prev-line
--exclude .build,build,DerivedData,dist,Sources/ClaudeManagerApp/Resources
